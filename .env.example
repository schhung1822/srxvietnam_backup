# Copy this file to `.env` or `.env.local` before running the app.
# On deployment, add the same variables in your hosting platform's environment settings.

NEXT_PUBLIC_SITE_URL=https://srx.eventhub.vn
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_TOKEN=

# Use either DATABASE_URL/MYSQL_URL/DB_URL or the individual DB_* variables below.
DATABASE_URL=
MYSQL_URL=
DB_URL=
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

NEXT_PUBLIC_SEPAY_BANK_NAME=
NEXT_PUBLIC_SEPAY_BANK_CODE=ACB
NEXT_PUBLIC_SEPAY_ACCOUNT_NAME=
NEXT_PUBLIC_SEPAY_ACCOUNT_NUMBER=93956886
NEXT_PUBLIC_SEPAY_QR_IMAGE_URL_TEMPLATE=https://qr.sepay.vn/img?acc=93956886&bank=ACB&amount={{amount}}&des={{orderNumber}}
NEXT_PUBLIC_SEPAY_TRANSFER_PREFIX=SRX
SEPAY_WEBHOOK_EXPECTED_ACCOUNT_NUMBER=93956886

NOCODB_FORM_URL=
NOCODB_FORM_TOKEN=
LARK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
